<Window x:Class="P5RCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P5R Fusion Planner: Save Reader"
        Height="540" Width="640"
        WindowStartupLocation="CenterScreen"
        Background="#0d0d0d"
        Foreground="#f5f5f5"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="P5Red"    Color="#e60012"/>
        <SolidColorBrush x:Key="P5Gold"   Color="#c8a84b"/>
        <SolidColorBrush x:Key="P5Card"   Color="#252525"/>
        <SolidColorBrush x:Key="P5Border" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="P5Gray"   Color="#9ca3af"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource P5Red}"/>
            <Setter Property="Foreground" Value="#f5f5f5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b0000e"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource P5Border}"/>
                    <Setter Property="Foreground" Value="{StaticResource P5Gray}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource P5Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="{StaticResource P5Red}"/>
                    <Setter Property="Foreground" Value="{StaticResource P5Red}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <Border Width="3" Background="{StaticResource P5Red}" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="P5R FUSION PLANNER" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource P5Gold}" Margin="0,2,0,0"/>
                <TextBlock Text="Save Reader" FontSize="20" FontWeight="Bold"
                           Foreground="#f5f5f5"/>
            </StackPanel>
        </StackPanel>

        <!-- Save folder display -->
        <Border Grid.Row="1" Background="{StaticResource P5Card}" Padding="12" Margin="0,0,0,12"
                BorderBrush="{StaticResource P5Red}" BorderThickness="2,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SAVE FOLDER" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource P5Red}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SaveFolderText" Text="-" FontSize="11"
                               Foreground="{StaticResource P5Gray}" TextWrapping="Wrap"
                               FontFamily="Consolas"/>
                </StackPanel>
                <Button Grid.Column="1" Content="BROWSE" Click="BrowseButton_Click"
                        Style="{StaticResource GhostButton}"
                        Margin="12,0,0,0" VerticalAlignment="Center"
                        FontSize="10" Padding="10,5"/>
            </Grid>
        </Border>

        <!-- Save slot list -->
        <Border Grid.Row="2" Background="{StaticResource P5Card}" Padding="6"
                BorderBrush="{StaticResource P5Red}" BorderThickness="2,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SAVE SLOTS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource P5Red}" Margin="6,4,0,6"/>

                <ListBox Grid.Row="1" x:Name="SlotList"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#f5f5f5"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3a1a1a"/>
                                    <Setter Property="Foreground" Value="#f5f5f5"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2a2a2a"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Status line -->
        <TextBlock Grid.Row="3" x:Name="StatusText"
                   Text="Click 'Read Selected Save' to begin."
                   Margin="0,16,0,16" FontSize="12"
                   Foreground="{StaticResource P5Gray}"
                   TextWrapping="Wrap"/>

        <!-- Action buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="ReadButton" Content="READ SELECTED SAVE" Click="ReadButton_Click"/>
            <Button Grid.Column="2" x:Name="OpenButton" Content="OPEN IN BROWSER" Click="OpenButton_Click"
                    Style="{StaticResource GhostButton}" IsEnabled="False"/>
            <Button Grid.Column="4" x:Name="CopyLinkButton" Content="COPY LINK" Click="CopyLinkButton_Click"
                    Style="{StaticResource GhostButton}" IsEnabled="False"/>
            <Button Grid.Column="6" x:Name="SaveJsonButton" Content="SAVE JSON" Click="SaveJsonButton_Click"
                    Style="{StaticResource GhostButton}" IsEnabled="False"/>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <TextBlock Text="P5R Fusion Planner Companion · " Foreground="#555" FontSize="10"/>
            <TextBlock Foreground="#555" FontSize="10">
                <Hyperlink NavigateUri="https://github.com/AemiliusXIV/P5RFusionCalc"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{StaticResource P5Gray}">
                    github.com/AemiliusXIV/P5RFusionCalc
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
